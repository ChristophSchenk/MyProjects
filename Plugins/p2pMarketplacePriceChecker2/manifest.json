{
  "manifest_version": 3,
  "name": "CSGO Roll Price Checker",
  "version": "1.0",
  "description": "Quicker price checking of Roll items via Csgoskins",
  "permissions": [
    "activeTab",
    "tabs",
    "https://www.csgoroll.com/"
  ],

  "icons": {
    "16": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.csgoroll.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "action": {
    "16": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  }
}